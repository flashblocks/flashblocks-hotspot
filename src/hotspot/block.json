{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "flashblocks/hotspot",
	"version": "0.1.0",
	"title": "Hotspot",
	"category": "media",
	"icon": "format-image",
	"description": "Select an image and place interactive hotspot markers on it.",
	"keywords": ["hotspot", "image", "interactive", "marker", "pin"],
	"textdomain": "flashblocks-hotspot",
	"attributes": {
		"mediaId": {
			"type": "number"
		},
		"mediaUrl": {
			"type": "string"
		},
		"mediaAlt": {
			"type": "string",
			"default": ""
		},
		"tooltipLocation": {
			"type": "string",
			"default": ""
		},
		"tooltipTrigger": {
			"type": "string",
			"default": "click"
		}
	},
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"spacing": {
			"margin": ["top", "bottom"]
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
